<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup control. Pairs with
  android:allowBackup="false" on the <application> tag so neither
  cloud backup nor device-to-device transfer exports KinBridge state.
  Session tokens, pairing info, and the Rust core's config must stay
  on the device they were provisioned for.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
